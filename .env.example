# ─────────────────────────────────────────────────────────────────────────────
# Nautilus Web Interface — Environment Variables
# Copy this file to .env and fill in the values before running in production.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Security (REQUIRED in production) ────────────────────────────────────────

# JWT signing secret — generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Admin account password — must be at least 12 chars
ADMIN_PASSWORD=change-me-strong-password

# Set to "production" to enforce strict security checks at startup
ENVIRONMENT=development

# ── CORS ─────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins
# In production set to your actual frontend URL, e.g.:
#   CORS_ORIGINS=https://myapp.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Frontend URLs (used at build time) ───────────────────────────────────────

# In production set to your actual server addresses, e.g.:
#   VITE_NAUTILUS_API_URL=https://api.myapp.example.com
VITE_NAUTILUS_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_ADMIN_DB_API_URL=http://localhost:8001

# ── Optional API Key Auth ─────────────────────────────────────────────────────

# Leave empty to use JWT-only authentication (recommended)
# Set to a random string to enable API key auth as alternative: openssl rand -hex 32
API_KEY=

# Admin DB API key (for admin_db_api service)
ADMIN_API_KEY=

# ── Ports ─────────────────────────────────────────────────────────────────────

BACKEND_PORT=8000
ADMIN_PORT=8001
FRONTEND_PORT=3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────

RATE_LIMIT_PER_MINUTE=200
LOGIN_RATE_LIMIT_PER_MINUTE=5

# ── JWT ───────────────────────────────────────────────────────────────────────

JWT_EXPIRE_HOURS=8
