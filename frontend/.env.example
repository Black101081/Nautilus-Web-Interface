# Nautilus Web Interface - Environment Configuration
# Copy this file to .env and fill in your values

# Backend API URLs
VITE_NAUTILUS_API_URL=http://localhost:8000
VITE_ADMIN_DB_API_URL=http://localhost:8001
VITE_WS_URL=ws://localhost:8000

# Optional: API key for authentication (must match server API_KEY env var)
# Leave blank to disable authentication
VITE_API_KEY=
