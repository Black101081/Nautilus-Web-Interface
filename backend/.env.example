# Nautilus Trader API - Environment Configuration
# Copy this file to .env and fill in your values

# CORS - comma-separated list of allowed origins
# Leave blank to allow all origins (development only)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# API Key Authentication
# Leave blank to disable authentication (development mode)
# In production, set a strong random value: openssl rand -hex 32
API_KEY=

# Server port
NAUTILUS_API_PORT=8000
